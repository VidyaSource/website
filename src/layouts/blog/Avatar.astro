---
import {Image} from 'astro:assets';
import {images} from "../../components/Images";
import linkedIn from '../../img/blog/linkedin.png'
const { name, profileUrl, image} = Astro.props
---

<a href={profileUrl} class="flex-shrink-0 group inline-flex items-center gap-2">
    <Image
            height={80}
            width={80}
            quality="max"
            class="inline-block h-10 w-10 rounded-full ring-2 ring-red-light dark:ring-gray"
            src={images[`/src${image}`]()}
            alt=""
            loading="eager"
    />
    <span class="text-sm font-medium text-red dark:text-red-light group-hover:text-blue">
        {name}
    </span>
    <Image height={16}
           width={18}
           class="inline-block opacity-60 group-hover:opacity-100 transition-opacity"
           src={linkedIn}
           alt={`${name} on LinkedIn`}
           quality="max"
           loading="eager"
    />
</a>
