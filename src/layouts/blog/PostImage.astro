---
import {Image} from 'astro:assets';
import { images} from "../../components/Images";
interface PostImageProps {
    width: number
    height: number
    alt: string
    src: string
}

const {height, width, alt, src} = Astro.props
console.log(src)

---
<figure class="relative mx-auto my-10">
    <Image alt={alt} src={images[`/src${src}`]()} class="w-full h-auto object-cover rounded-lg shadow-md" />
    {alt && <figcaption class="mt-3 text-center text-sm text-gray italic">{alt}</figcaption>}
</figure>
