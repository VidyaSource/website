---
interface Props {
    title: string
    description: string
    category: string
}

const {title, description, category} = Astro.props
---
<section class="relative bg-gradient-to-br from-blue-light via-white to-blue-light dark:from-blue-dark dark:via-gray-dark dark:to-blue overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="absolute -top-10 -right-20 w-72 h-72 bg-red/10 dark:bg-red-light/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-10 -left-20 w-80 h-80 bg-blue/10 dark:bg-blue-light/10 rounded-full blur-3xl"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-green/5 dark:bg-green-light/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto py-20 px-4 sm:py-28 sm:px-6 lg:px-8">
        <div class="text-center">
            <!-- Category badge -->
            <span class="inline-block px-4 py-1.5 text-xs font-semibold tracking-widest uppercase rounded-full bg-green-dark text-green-light dark:bg-green-dark dark:text-green-light mb-6">
                {category}
            </span>

            <h2 class="mt-2 text-4xl font-extrabold text-red dark:text-red-light sm:text-5xl sm:tracking-tight lg:text-6xl leading-tight">
                {title}
            </h2>
            <p class="max-w-2xl mt-6 mx-auto text-xl text-gray-dark dark:text-blue-light leading-relaxed">
                {description}
            </p>

            <!-- Decorative divider -->
            <div class="mt-10 flex items-center justify-center">
                <div class="w-16 h-1 rounded-full bg-red dark:bg-red-light"></div>
            </div>
        </div>
    </div>
</section>
