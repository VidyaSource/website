---
import {type Course} from '../../layouts/courses/courseUtils';
import CourseHeader from '../../layouts/courses/CourseHeader.astro'
import Description from "../../layouts/courses/Description.astro";
import Syllabus from '../../layouts/courses/Syllabus.astro'
import Instructor from "../../layouts/courses/Instructor.astro";
import CallToAction from "../../components/CallToAction.astro"

type Props = Course

const {title, description, category, syllabus, duration, badge, instructor, render, instructor: {title: instructorTitle, name, quote, image}} = Astro.props
const { Content } = await render();
---
<CourseHeader title={title} description={description} category={category} />
<Description title={title}>
    <Content />
</Description>
<Syllabus syllabus={syllabus} duration={duration} />
<Instructor title={instructorTitle} name={name} image={image} quote={quote} badge={badge} />
<CallToAction/>