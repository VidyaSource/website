---
import {Image} from 'astro:assets';
import team from '../../img/courses/team2.jpg'

---
<div class="relative bg-white dark:bg-gray overflow-hidden">
    <!-- Subtle decorative accent -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-blue/5 dark:bg-blue-light/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2" aria-hidden="true"></div>

    <div class="mx-auto max-w-7xl lg:grid lg:grid-cols-12 lg:gap-x-12 lg:px-8">
        <div class="px-6 pb-14 pt-12 lg:col-span-7 lg:px-0 lg:pt-20 lg:pb-20 xl:col-span-6">
            <div class="mx-auto max-w-2xl lg:mx-0">
                <slot/>
            </div>
        </div>
        <div class="relative lg:col-span-5 lg:-mr-8 xl:absolute xl:inset-0 xl:left-1/2 xl:mr-0">
            <div class="h-full w-full lg:p-8">
                <Image
                    src={team}
                    alt="Collaborating software engineers"
                    quality={100}
                    class="w-full h-full object-cover lg:rounded-2xl lg:shadow-xl"
                />
            </div>
        </div>
    </div>
</div>
