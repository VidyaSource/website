---
import BlogPostCard from '../../layouts/blog/BlogPostCard.astro'
import {blogPosts, BlogPost} from "../blog/blogUtils";

const recentPosts: Array<BlogPost> = await blogPosts.slice(0, 3)

---

<div class="relative bg-white dark:bg-gray-dark pt-16 pb-20 px-4 sm:px-6 lg:pt-24 lg:pb-28 lg:px-8 overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue/20 to-transparent" aria-hidden="true"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue/5 dark:bg-blue-light/5 rounded-full blur-3xl" aria-hidden="true"></div>
    <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-red/5 dark:bg-red-light/5 rounded-full blur-3xl" aria-hidden="true"></div>

    <section class="relative max-w-7xl mx-auto">
        <div class="text-center">
            <p class="text-sm font-semibold tracking-widest uppercase text-green-dark dark:text-green-light mb-3">Insights & Ideas</p>
            <h2 class="text-3xl tracking-tight font-extrabold text-red dark:text-red-light sm:text-4xl">The latest from the Vidya blog</h2>
            <p class="mt-4 max-w-2xl mx-auto text-lg text-gray-dark dark:text-blue-light leading-relaxed sm:mt-5">
                Discover <a href="/blog" class="font-semibold underline decoration-2 underline-offset-4 decoration-green-dark dark:decoration-green-light hover:decoration-red">new insights</a> into everything from agile software development to innovative
                engineering techniques to the
                impact of technology on our world.
            </p>
            <!-- Decorative divider -->
            <div class="mt-6 flex items-center justify-center">
                <div class="w-12 h-1 rounded-full bg-red dark:bg-red-light"></div>
            </div>
        </div>
        <div class="mt-12 max-w-lg mx-auto grid gap-8 lg:grid-cols-3 lg:max-w-none">
            {recentPosts.map(p => {
                return (
                    <BlogPostCard {...p} classes="bg-blue-light" />
                )
            })}
        </div>
        <div class="mt-12 text-center">
            <a href="/blog" class="inline-flex items-center px-6 py-3 text-base font-semibold rounded-xl
                text-blue-dark dark:text-blue-light
                border-2 border-blue dark:border-blue-light
                hover:bg-blue-light dark:hover:bg-blue/30
                transition-all duration-200">
                View All Posts
                <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
            </a>
        </div>
    </section>
</div>
