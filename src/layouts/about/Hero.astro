---
import {Image} from 'astro:assets';
import image from '../../img/about/computers.jpg'
---
<div class="relative overflow-hidden">
    <!-- Full-width hero image with overlay -->
    <div class="absolute inset-0">
        <Image
            class="object-cover w-full h-full"
            src={image}
            alt="A team working together on their laptops"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-gray-dark/90 via-gray-dark/70 to-gray-dark/40"></div>
    </div>

    <!-- Decorative orbs -->
    <div class="absolute top-10 left-10 w-72 h-72 bg-blue rounded-full opacity-10 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-10 right-20 w-96 h-96 bg-red rounded-full opacity-10 blur-3xl" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-7xl px-6 py-24 lg:px-8 lg:py-36">
        <div class="max-w-2xl">
            <span class="inline-block px-4 py-1.5 text-xs font-semibold tracking-widest uppercase bg-blue text-white rounded-full mb-6">
                About Us
            </span>
            <h1 class="text-4xl tracking-tight font-extrabold text-white sm:text-5xl md:text-6xl">
                <span class="block">Vidya is a software services and consulting company</span>
                <span class="block text-blue-light mt-2">based in Washington, DC, USA</span>
            </h1>
            <div class="mt-6 w-16 h-1 bg-red rounded-full"></div>
        </div>
    </div>
</div>
