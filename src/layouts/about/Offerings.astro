---
import {Image} from 'astro:assets';
import capabilityStatement from "../../img/about/vidya-capability-statement.webp"
---
<div class="relative bg-white dark:bg-gray-dark overflow-hidden">
    <!-- Decorative orbs -->
    <div class="absolute top-20 right-0 w-80 h-80 bg-blue rounded-full opacity-5 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-40 left-0 w-64 h-64 bg-red rounded-full opacity-5 blur-3xl" aria-hidden="true"></div>

    <div class="relative px-6 py-20 lg:px-8 lg:py-28 max-w-7xl mx-auto">
        <!-- Our Mission -->
        <section class="text-center mb-20">
            <span class="inline-block px-4 py-1.5 text-xs font-semibold tracking-widest uppercase bg-blue text-white rounded-full">
                Who We Are
            </span>
            <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-red dark:text-red-light sm:text-5xl">
                Our Mission
            </h1>
            <div class="mt-4 mx-auto w-16 h-1 bg-red rounded-full"></div>
            <div class="mt-8 max-w-3xl mx-auto space-y-6">
                <p class="text-lg leading-relaxed text-gray-dark dark:text-blue-light">
                    Vidya, LLC builds modernized on-premise, cloud, and hybrid solutions for commercial businesses and
                    government agencies according to their strategic objectives. Our work proves there
                    is no need to choose between continuous delivery and high quality.
                </p>
                <p class="text-lg leading-relaxed text-gray-dark dark:text-blue-light">
                    Federal SBA 8(a), Commonwealth of Virginia SWaM, and multiple commercial certifications as a
                    minority-owned business are testament to
                    our ability not only to deliver lean, innovative solutions for our clients but
                    also to do so the right way using techniques like agile development, DevSecOps, and automated
                    testing not only for functionality but also for security, accessibility, and performance.
                </p>
            </div>
        </section>

        <!-- Our Differentiators -->
        <section class="mb-20">
            <div class="text-center mb-10">
                <span class="inline-block px-4 py-1.5 text-xs font-semibold tracking-widest uppercase bg-red text-white rounded-full">
                    Why Vidya
                </span>
                <h2 class="mt-6 text-3xl font-extrabold tracking-tight text-red dark:text-red-light sm:text-4xl">
                    Our Differentiators
                </h2>
                <div class="mt-4 mx-auto w-16 h-1 bg-red rounded-full"></div>
                <p class="mt-6 text-lg text-gray-dark dark:text-blue-light max-w-2xl mx-auto">
                    These are some of the values that distinguish Vidya, LLC from others in the space:
                </p>
            </div>
            <div class="grid gap-6 md:grid-cols-2 max-w-5xl mx-auto">
                <div class="group p-6 bg-gradient-to-b from-white to-gray-light dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray">
                    <div class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gradient-to-br from-blue to-blue-dark text-white rounded-lg text-sm font-bold">1</span>
                        <p class="text-gray-dark dark:text-blue-light leading-relaxed">Proven track record of modernizing cloud-scale software by integrating
                            leading edge technologies with legacy systems to generate more value for your organization. For example,
                            Vidya helped the State Department reduce passport renewal time from
                            months to days with <a href="https://servicetoamericamedals.org/honorees/luis-coronado-jr-matt-pierce-and-the-online-passport-renewal-team/" class="text-blue hover:text-blue-dark underline underline-offset-2">97% customer satisfaction and 80% increased trust in government</a></p>
                    </div>
                </div>
                <div class="group p-6 bg-gradient-to-b from-white to-gray-light dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray">
                    <div class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gradient-to-br from-blue to-blue-dark text-white rounded-lg text-sm font-bold">2</span>
                        <p class="text-gray-dark dark:text-blue-light leading-relaxed">Dedication to communication, which is the basis for teamwork, transparency, accountability, and humility as we don't know everything</p>
                    </div>
                </div>
                <div class="group p-6 bg-gradient-to-b from-white to-gray-light dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray">
                    <div class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gradient-to-br from-blue to-blue-dark text-white rounded-lg text-sm font-bold">3</span>
                        <p class="text-gray-dark dark:text-blue-light leading-relaxed">Commitment to listen to understand your unique business problems and solve them as simply as possible</p>
                    </div>
                </div>
                <div class="group p-6 bg-gradient-to-b from-white to-gray-light dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray">
                    <div class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gradient-to-br from-blue to-blue-dark text-white rounded-lg text-sm font-bold">4</span>
                        <p class="text-gray-dark dark:text-blue-light leading-relaxed">Expertise across disparate disciplines like modern UI, APIs, data engineering and analytics, and cybersecurity</p>
                    </div>
                </div>
                <div class="group p-6 bg-gradient-to-b from-white to-gray-light dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray">
                    <div class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gradient-to-br from-blue to-blue-dark text-white rounded-lg text-sm font-bold">5</span>
                        <p class="text-gray-dark dark:text-blue-light leading-relaxed">Understanding the profound influence non-technical disciplines like <a href="/blog/why-coding-interviews-are-the-worst" class="text-blue hover:text-blue-dark underline underline-offset-2">recruiting</a> and <a href="https://ditap.learning-transformation.com/assets/courseware/v1/aae244dc51e2e3a16613bee911809da0/asset-v1:ICF+DITAP01+2018_T1+type@asset+block/ICF-ASI_Team_Phase_II_Submission_For_the_DSCPT_Development_Program_Challenge.pdf" class="text-blue hover:text-blue-dark underline underline-offset-2">contracting</a> have on the success of technology initiatives</p>
                    </div>
                </div>
                <div class="group p-6 bg-gradient-to-b from-white to-gray-light dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray">
                    <div class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gradient-to-br from-blue to-blue-dark text-white rounded-lg text-sm font-bold">6</span>
                        <p class="text-gray-dark dark:text-blue-light leading-relaxed">Staff with PMP and agile certifications</p>
                    </div>
                </div>
                <div class="group p-6 bg-gradient-to-b from-white to-gray-light dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray">
                    <div class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gradient-to-br from-blue to-blue-dark text-white rounded-lg text-sm font-bold">7</span>
                        <p class="text-gray-dark dark:text-blue-light leading-relaxed">Published content, public speaking, and cited for expertise in multiple government reports like <a href="https://www.gao.gov/assets/gao-12-681.pdf" class="text-blue hover:text-blue-dark underline underline-offset-2">this one</a></p>
                    </div>
                </div>
                <div class="group p-6 bg-gradient-to-b from-white to-gray-light dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray">
                    <div class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-gradient-to-br from-blue to-blue-dark text-white rounded-lg text-sm font-bold">8</span>
                        <p class="text-gray-dark dark:text-blue-light leading-relaxed">Course instruction because you don't really know something unless you can teach it</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Our Services -->
        <section class="mb-20">
            <div class="text-center mb-10">
                <span class="inline-block px-4 py-1.5 text-xs font-semibold tracking-widest uppercase bg-green-dark text-white rounded-full">
                    What We Do
                </span>
                <h2 class="mt-6 text-3xl font-extrabold tracking-tight text-red dark:text-red-light sm:text-4xl">
                    Our Services
                </h2>
                <div class="mt-4 mx-auto w-16 h-1 bg-red rounded-full"></div>
            </div>
            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 max-w-5xl mx-auto">
                <div class="relative p-6 bg-gradient-to-b from-blue-light to-white dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray text-center">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue to-blue-dark rounded-t-2xl"></div>
                    <h3 class="text-lg font-bold text-blue-dark dark:text-blue mb-3">Engineering & Architecture</h3>
                    <p class="text-gray-dark dark:text-blue-light leading-relaxed text-sm">Software engineering and architecture for your organization to generate value from assets you're leaving on the table</p>
                </div>
                <div class="relative p-6 bg-gradient-to-b from-blue-light to-white dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray text-center">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red to-red rounded-t-2xl"></div>
                    <h3 class="text-lg font-bold text-blue-dark dark:text-blue mb-3">Culture & Mentorship</h3>
                    <p class="text-gray-dark dark:text-blue-light leading-relaxed text-sm">Assessing the current state of your engineering culture and optimizing your recruiting and contracting practices to motivate the right values through mentorship</p>
                </div>
                <div class="relative p-6 bg-gradient-to-b from-blue-light to-white dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray text-center">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-green to-green-dark rounded-t-2xl"></div>
                    <h3 class="text-lg font-bold text-blue-dark dark:text-blue mb-3">Technical Communications</h3>
                    <p class="text-gray-dark dark:text-blue-light leading-relaxed text-sm">Technical communications to express the complexity of your work in ways everyone can understand</p>
                </div>
                <div class="relative p-6 bg-gradient-to-b from-blue-light to-white dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray text-center md:col-span-1 lg:col-span-1">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-dark to-blue rounded-t-2xl"></div>
                    <h3 class="text-lg font-bold text-blue-dark dark:text-blue mb-3">Training Courses</h3>
                    <p class="text-gray-dark dark:text-blue-light leading-relaxed text-sm">Training courses focused on the practical lessons that make you more productive and marketable in the real world</p>
                </div>
                <div class="relative p-6 bg-gradient-to-b from-blue-light to-white dark:from-gray-dark dark:to-gray-dark rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-light dark:border-gray text-center md:col-span-1 lg:col-span-1">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red to-blue rounded-t-2xl"></div>
                    <h3 class="text-lg font-bold text-blue-dark dark:text-blue mb-3">Content & Tutorials</h3>
                    <p class="text-gray-dark dark:text-blue-light leading-relaxed text-sm">Blog posts and video tutorials on software development and the ways technology impacts the world</p>
                </div>
            </div>
        </section>

        <!-- Capability Statement -->
        <section class="text-center">
            <span class="inline-block px-4 py-1.5 text-xs font-semibold tracking-widest uppercase bg-blue text-white rounded-full">
                At a Glance
            </span>
            <h2 class="mt-6 text-3xl font-extrabold tracking-tight text-red dark:text-red-light sm:text-4xl">
                Our Capability Statement
            </h2>
            <div class="mt-4 mx-auto w-16 h-1 bg-red rounded-full"></div>
            <div class="mt-10 max-w-2xl mx-auto">
                <div class="rounded-2xl shadow-xl overflow-hidden border border-gray-light dark:border-gray">
                    <Image
                        height="792"
                        width="612"
                        quality={100}
                        class="w-full"
                        src={capabilityStatement}
                        alt="Vidya Capability Statement"
                    />
                </div>
                <p class="mt-6 text-lg text-gray-dark dark:text-blue-light">
                    You can also view the <a href="/vidya-capability-statement.pdf" target="_blank" class="text-blue hover:text-blue-dark underline underline-offset-2">Vidya Capability Statement as a PDF</a>.
                </p>
            </div>
        </section>
    </div>
</div>
