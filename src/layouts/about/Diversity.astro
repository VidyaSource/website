---
import {Image} from 'astro:assets';
import president from '../../img/staff/president.png'
---
<div class="relative bg-gradient-to-br from-red-light via-white to-red-light dark:from-gray dark:via-gray-dark dark:to-gray overflow-hidden">
    <!-- Decorative orbs -->
    <div class="absolute top-10 left-10 w-72 h-72 bg-red rounded-full opacity-5 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-10 right-10 w-80 h-80 bg-green rounded-full opacity-5 blur-3xl" aria-hidden="true"></div>

    <div class="relative max-w-7xl mx-auto px-6 py-20 lg:px-8 lg:py-28">
        <div class="text-center mb-12">
            <span class="inline-block px-4 py-1.5 text-xs font-semibold tracking-widest uppercase bg-red text-white rounded-full">
                Our Values
            </span>
            <h2 class="mt-6 text-3xl font-extrabold tracking-tight text-red dark:text-red-light sm:text-4xl">
                Great Technology Needs All of Us
            </h2>
            <div class="mt-4 mx-auto w-16 h-1 bg-red rounded-full"></div>
        </div>

        <div class="max-w-4xl mx-auto">
            <div class="relative bg-white dark:bg-gray-dark rounded-2xl shadow-xl p-8 lg:p-12 border border-gray-light dark:border-gray">
                <!-- Decorative quote mark -->
                <svg class="absolute top-6 left-6 w-16 h-16 text-red opacity-10" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true">
                    <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z" />
                </svg>

                <div class="relative lg:flex lg:items-center lg:gap-12">
                    <div class="hidden lg:block lg:flex-shrink-0">
                        <div class="w-48 h-48 xl:w-56 xl:h-56 relative">
                            <Image
                                quality={100}
                                class="rounded-full object-cover ring-4 ring-red/20"
                                src={president}
                                alt="Neil Chaudhuri (He/Him), President of Vidya"
                            />
                        </div>
                    </div>
                    <div>
                        <blockquote>
                            <p class="text-xl lg:text-2xl leading-relaxed text-gray-dark dark:text-blue-light font-medium">
                                We are a passionate advocate for diversity in technology. Prejudice against anyone
                                on the basis of gender, race, ethnicity, nationality, religion, orientation, ability,
                                or even academic background not only limits our individual growth but also limits the creative energy necessary to develop the best software.
                            </p>
                        </blockquote>
                        <div class="mt-8 flex items-center gap-4 pt-6 border-t border-gray-light dark:border-gray">
                            <div class="lg:hidden flex-shrink-0">
                                <div class="h-12 w-12 relative">
                                    <Image
                                        class="rounded-full object-cover ring-2 ring-red/20"
                                        quality={100}
                                        src={president}
                                        alt="Neil Chaudhuri (He/Him), President of Vidya"
                                    />
                                </div>
                            </div>
                            <div>
                                <div class="text-base font-semibold text-gray-dark dark:text-blue-light">Neil Chaudhuri</div>
                                <div class="text-sm font-medium text-red dark:text-red-light">President, Vidya</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
