---
// Contact form. React-free: a plain <form> with a small client script that
// POSTs to /api/contact and swaps in a thank-you message on success.
---
<section class="bg-blue-light dark:bg-gray-dark">
    <div class="max-w-7xl mx-auto py-16 px-4 sm:py-24 sm:px-6 lg:px-8">
        <div class="relative bg-white shadow-xl">
            <h1 class="sr-only">Contact Vidya</h1>

            <div class="grid grid-cols-1 lg:grid-cols-3">
                {/* Contact information */}
                <div class="relative overflow-hidden py-10 px-6 bg-blue sm:px-10 xl:p-12">
                    <div class="absolute inset-0 pointer-events-none sm:hidden" aria-hidden="true">
                        <svg class="absolute inset-0 w-full h-full" width="343" height="388" viewBox="0 0 343 388" fill="none" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                            <path d="M-99 461.107L608.107-246l707.103 707.107-707.103 707.103L-99 461.107z" fill="url(#linear1)" fill-opacity=".1"/>
                            <defs>
                                <linearGradient id="linear1" x1="254.553" y1="107.554" x2="961.66" y2="814.66" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#fff"/>
                                    <stop offset="1" stop-color="#fff" stop-opacity="0"/>
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                    <div class="hidden absolute top-0 right-0 bottom-0 w-1/2 pointer-events-none sm:block lg:hidden" aria-hidden="true">
                        <svg class="absolute inset-0 w-full h-full" width="359" height="339" viewBox="0 0 359 339" fill="none" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                            <path d="M-161 382.107L546.107-325l707.103 707.107-707.103 707.103L-161 382.107z" fill="url(#linear2)" fill-opacity=".1"/>
                            <defs>
                                <linearGradient id="linear2" x1="192.553" y1="28.553" x2="899.66" y2="735.66" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#fff"/>
                                    <stop offset="1" stop-color="#fff" stop-opacity="0"/>
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                    <div class="hidden absolute top-0 right-0 bottom-0 w-1/2 pointer-events-none lg:block" aria-hidden="true">
                        <svg class="absolute inset-0 w-full h-full" width="160" height="678" viewBox="0 0 160 678" fill="none" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                            <path d="M-161 679.107L546.107-28l707.103 707.107-707.103 707.103L-161 679.107z" fill="url(#linear3)" fill-opacity=".1"/>
                            <defs>
                                <linearGradient id="linear3" x1="192.553" y1="325.553" x2="899.66" y2="1032.66" gradientUnits="userSpaceOnUse">
                                    <stop stop-color="#fff"/>
                                    <stop offset="1" stop-color="#fff" stop-opacity="0"/>
                                </linearGradient>
                            </defs>
                        </svg>
                    </div>
                    <h1 class="text-lg font-medium text-white">Contact Vidya</h1>
                    <p class="mt-6 text-base text-white max-w-3xl">
                        We would love to work with you and help you use technology to grow your business or
                        jumpstart your career.
                        Please let us know how we can help!
                    </p>
                    <dl class="mt-8 space-y-6">
                        <dt>
                            <span class="sr-only">Phone number</span>
                        </dt>
                        <dd class="flex text-base text-white hover:text-blue-light">
                            <svg class="flex-shrink-0 w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
                            </svg>
                            <span class="ml-3">+1 (202) 430-5695</span>
                        </dd>
                        <dt>
                            <span class="sr-only">Email</span>
                        </dt>
                        <dd class="flex text-base text-white">
                            <svg class="flex-shrink-0 w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
                            </svg>
                            <span class="ml-3">info@vidyasource.com</span>
                        </dd>
                    </dl>
                    <ul class="mt-8 flex space-x-12" role="list">
                        <li>
                            <a class="text-blue-light hover:text-white" href="https://www.linkedin.com/company/vidya-technology-training">
                                <span class="sr-only">LinkedIn</span>
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" aria-hidden="true">
                                    <title>LinkedIn icon</title>
                                    <path fill-rule="evenodd" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" clip-rule="evenodd" fill="currentColor"/>
                                </svg>
                            </a>
                        </li>
                        <li>
                            <a class="text-blue-light hover:text-white" href="https://github.com/VidyaSource">
                                <span class="sr-only">GitHub</span>
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" aria-hidden="true">
                                    <path d="M11.999 0C5.373 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.386.6.11.819-.26.819-.578 0-.284-.01-1.04-.017-2.04-3.337.724-4.042-1.61-4.042-1.61-.545-1.386-1.332-1.755-1.332-1.755-1.09-.744.082-.73.082-.73 1.205.086 1.838 1.238 1.838 1.238 1.07 1.833 2.81 1.304 3.493.996.109-.775.419-1.303.762-1.603C7.145 17 4.343 15.97 4.343 11.373c0-1.31.468-2.382 1.236-3.22-.124-.304-.536-1.524.118-3.176 0 0 1.007-.323 3.3 1.23.956-.266 1.983-.4 3.003-.404 1.02.005 2.046.138 3.005.404 2.29-1.553 3.296-1.23 3.296-1.23.655 1.652.243 2.872.12 3.176.77.838 1.233 1.91 1.233 3.22 0 4.61-2.806 5.624-5.478 5.921.43.37.814 1.103.814 2.223 0 1.603-.015 2.898-.015 3.291 0 .321.217.695.825.578C20.565 21.796 24 17.3 24 12c0-6.627-5.373-12-12.001-12" fill="currentColor"/>
                                </svg>
                            </a>
                        </li>
                    </ul>
                </div>

                {/* Contact form */}
                <div data-form-wrap class="py-10 px-6 sm:px-10 lg:col-span-2 xl:p-12 dark:bg-red">
                    <h3 class="text-lg font-medium text-gray-dark dark:text-red-light">Send us a message</h3>
                    <form id="contact-form" class="mt-6 grid grid-cols-1 gap-y-6 sm:grid-cols-2 sm:gap-x-8">
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-dark dark:text-red-light">
                                Email
                            </label>
                            <div class="mt-1">
                                <input
                                    id="email"
                                    name="EMAIL"
                                    type="email"
                                    required
                                    autocomplete="email"
                                    class="py-3 px-4 block w-full shadow-sm text-gray-dark focus:ring-white0 focus:border-white0 border-gray-dark rounded-md"
                                />
                            </div>
                        </div>
                        <div class="sm:col-span-2">
                            <label for="subject" class="block text-sm font-medium text-gray-dark dark:text-red-light">
                                Subject
                            </label>
                            <div class="mt-1">
                                <input
                                    type="text"
                                    name="subject"
                                    id="subject"
                                    required
                                    class="py-3 px-4 block w-full shadow-sm text-gray-dark focus:ring-white0 focus:border-white0 border-gray-dark rounded-md"
                                />
                            </div>
                        </div>
                        <div class="sm:col-span-2">
                            <div class="flex justify-between">
                                <label for="message" class="block text-sm font-medium text-gray-dark dark:text-red-light">
                                    Message
                                </label>
                                <span id="message-max" class="text-sm text-gray-dark dark:text-red-light">
                                    Max. 500 characters
                                </span>
                            </div>
                            <div class="mt-1">
                                <textarea
                                    id="message"
                                    name="message"
                                    rows="4"
                                    maxlength="500"
                                    required
                                    class="py-3 px-4 block w-full shadow-sm text-gray-dark focus:ring-white0 focus:border-white0 border border-gray-dark rounded-md"
                                    aria-describedby="message-max"
                                ></textarea>
                            </div>
                        </div>
                        {/* Honeypot: hidden from sighted users and assistive tech; bots that fill every field trip this */}
                        <div style="position:absolute; left:-9999px; top:-9999px;" aria-hidden="true">
                            <label for="website">Leave this field blank</label>
                            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
                        </div>
                        <div class="sm:col-span-2">
                            <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}></div>
                        </div>
                        <p id="contact-error" class="hidden sm:col-span-2 text-sm text-red" role="alert"></p>
                        <div class="sm:col-span-2 sm:flex sm:justify-end">
                            <button
                                type="submit"
                                class="mt-2 w-full inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-blue hover:bg-green focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white0 sm:w-auto"
                            >
                                Submit
                            </button>
                        </div>
                    </form>
                </div>
                <div id="contact-thanks" class="hidden py-10 px-6 sm:px-10 lg:col-span-2 xl:p-12">
                    <h3 class="text-lg font-medium text-gray-dark">Thank you! Talk to you soon!</h3>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
<script>
    declare const turnstile: { reset: (widget?: string | HTMLElement) => void } | undefined;

    function initContactForm() {
        const form = document.getElementById('contact-form') as HTMLFormElement | null;
        if (!form) return;
        const wrap = form.closest('[data-form-wrap]');
        const thanks = document.getElementById('contact-thanks');
        const errorEl = document.getElementById('contact-error');
        const turnstileWidget = form.querySelector('.cf-turnstile') as HTMLElement | null;
        const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

        const showError = (message: string) => {
            if (!errorEl) return;
            errorEl.textContent = message;
            errorEl.classList.remove('hidden');
        };

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorEl?.classList.add('hidden');

            const data = new FormData(form);
            const from = data.get('EMAIL');
            const subject = data.get('subject');
            const message = data.get('message');
            const website = data.get('website') ?? '';
            const turnstileToken = data.get('cf-turnstile-response') ?? '';

            if (!from || !subject || !message) return;

            if (submitButton) submitButton.disabled = true;
            try {
                const response = await fetch('/api/contact', {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json, text/plain, */*',
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({from, subject, message, website, turnstileToken})
                });
                const result = await response.json().catch(() => null);

                if (response.ok && result?.ok) {
                    wrap?.classList.add('hidden');
                    thanks?.classList.remove('hidden');
                } else {
                    showError(result?.error || 'Something went wrong. Please try again.');
                }
            } catch {
                showError('Something went wrong. Please try again.');
            } finally {
                if (submitButton) submitButton.disabled = false;
                // Reset is best-effort: an unrendered/invalid widget throws, and that must
                // never clobber the error message already shown above.
                try {
                    if (typeof turnstile !== 'undefined' && turnstileWidget) {
                        turnstile.reset(turnstileWidget);
                    }
                } catch {
                    // ignore
                }
            }
        });
    }

    document.addEventListener('astro:page-load', initContactForm);
</script>
