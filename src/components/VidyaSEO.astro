---
import {Seo} from "astro-seo-meta";
import {Schema} from "astro-seo-schema"

interface Props {
    title?: string
    description?: string
    type?: string
    image?: string
    noindex?: boolean
    nofollow?: boolean
    meta?: Array<{name: string, content: string}>
    schema?: any
    openGraph?: any
    twitterCard?: string
}

const {title, description, type, image, meta, noindex, nofollow, schema, openGraph, twitterCard} = Astro.props

const modifiedTitle = title ?? "Vidya | AI & Cloud Consulting and Modernization"
const modifiedDescription = description ?? "Vidya is a certified IT consulting firm specializing in AI, cloud, and software modernization services. Partner with our experts to transform your organization."

const base = Astro.site ?? new URL(Astro.url.origin)
const absoluteImage = new URL(image ?? "/vidya-social.png", base).href
const canonicalUrl = new URL(Astro.url.pathname, base).href
const ogType = type ?? (openGraph?.article ? "article" : "website")
const robots = `${noindex ? "noindex" : "index"}, ${nofollow ? "nofollow" : "follow"}`
const article = openGraph?.article
---
<Seo title={modifiedTitle}
     description={modifiedDescription}
     robots={robots}
     facebook={{
         image: absoluteImage,
         url: canonicalUrl,
         type: ogType
     }}
     twitter={{
         image: absoluteImage,
         card: twitterCard ?? "summary_large_image"
     }}
/>
<link rel="canonical" href={canonicalUrl}>
<meta property="og:site_name" content="Vidya LLC">
<meta property="og:locale" content="en_US">
<meta property="og:image:alt" content={modifiedTitle}>
{article?.publishedTime && <meta property="article:published_time" content={new Date(article.publishedTime).toISOString()}>}
{article?.authors?.map((a: string) => <meta property="article:author" content={a}>)}
{article?.tags?.map((t: string) => <meta property="article:tag" content={t}>)}
{(meta ?? []).map((m) => <meta name={m.name} content={m.content}>)}
{schema && <Schema item={schema}/> }
