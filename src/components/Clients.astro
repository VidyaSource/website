---
import {Image} from 'astro:assets';

import dos from '../img/partners/dos.svg'
import aaif from '../img/partners/AAIF_Primary_Logo_Black.svg'
import neustar from '../img/partners/neustar.png'
import trss from '../img/partners/trss.png'
import healthCareGov from '../img/partners/healthcaregov.png'
import ninaday from '../img/partners/ninaday.svg'
import eop from '../img/partners/eop.svg'
import eureka from '../img/partners/eureka.png'
import gsa from '../img/partners/gsa.png'
import mediabarn from '../img/partners/mediabarn.png'
import recreation from '../img/partners/recreation.svg'
import concurrentRealtime from '../img/partners/concurrent.png'

const partners = [
    {src: aaif, alt: 'Agentic AI Foundation'},
    {src: dos, alt: 'United States Department of State'},
    {src: neustar, alt: 'Neustar'},
    {src: eop, alt: 'Executive Office of the President of the United States'},
    {src: trss, alt: 'Thomson Reuters Special Services'},
    {src: healthCareGov, alt: 'Healthcare.gov'},
    {src: ninaday, alt: 'Ninaday'},
    {src: gsa, alt: 'Government Services Administration'},
    {src: eureka, alt: 'Eureka Golf Products'},
    {src: mediabarn, alt: 'MediaBarn'},
    {src: recreation, alt: 'Recreation.gov', width: 200},
    {src: concurrentRealtime, alt: 'Concurrent Real-Time', width: 200},
]
---

<section class="relative bg-green-light dark:bg-blue overflow-hidden">
    <!-- Decorative accents -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-green-dark/20 to-transparent" aria-hidden="true"></div>
    <div class="absolute -top-32 -left-32 w-64 h-64 bg-green/10 dark:bg-green-light/5 rounded-full blur-3xl" aria-hidden="true"></div>

    <div class="relative max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:py-24 lg:px-8">
        <div class="lg:grid lg:grid-cols-2 lg:gap-12 lg:items-center">
            <div>
                <p class="text-sm font-semibold tracking-widest uppercase text-green-dark dark:text-green-light mb-3">Our Partners</p>
                <h2 class="text-3xl font-extrabold text-red dark:text-red-light sm:text-4xl lg:text-5xl leading-tight">
                    Government and business trust Vidya.
                </h2>
                <div class="mt-5 h-1 w-16 rounded-full bg-green"></div>
            </div>
            <div class="mt-6 lg:mt-0">
                <p class="text-lg text-gray-dark dark:text-blue-light leading-relaxed">
                    We are a certified minority-owned business proud to have brought our expertise and insight to large
                    government agencies, small businesses, and everything in between to help them all capitalize on an
                    ever-evolving technology landscape.
                </p>
                <div class="mt-6">
                    <div class="inline-block rounded-xl shadow-lg">
                        <a href="/contact" class="flex contact-us">
                            Contact Us
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <ul role="list" class="mt-14 grid grid-cols-2 gap-4 auto-rows-fr sm:grid-cols-3 lg:mt-16 lg:grid-cols-4">
            {partners.map((partner) => (
                <li class="flex justify-center items-center min-h-32 p-5 bg-white dark:bg-blue-light rounded-xl shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
                    <Image src={partner.src} alt={partner.alt} width={partner.width} class="max-h-24 w-auto object-contain" />
                </li>
            ))}
        </ul>
    </div>
</section>
